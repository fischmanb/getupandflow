{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/faq", "destination": "/", "statusCode": 302 }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
